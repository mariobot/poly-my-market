@using Radzen
@using Radzen.Blazor

<div class="rz-sidebar">
    <RadzenStack Gap="0">
        <!-- Brand Header -->
        <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-p-4 rz-background-color-primary" Style="border-bottom: 1px solid var(--rz-border-color);">
            <RadzenIcon Icon="account_balance" Style="font-size: 2rem; color: var(--rz-white);" />
            <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-white); font-weight: bold; margin: 0;">
                PolyMyMarket
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-white); opacity: 0.9; margin: 0;">
                Prediction Markets
            </RadzenText>
        </RadzenStack>

        <!-- Navigation Menu -->
        <RadzenPanelMenu Style="width: 100%;">
            <RadzenPanelMenuItem Text="Home" Path="" Icon="home" />

            <RadzenPanelMenuItem Text="Markets" Icon="show_chart">
                <RadzenPanelMenuItem Text="Browse Markets" Path="markets" Icon="list" />
                <RadzenPanelMenuItem Text="Create Market" Path="create-market" Icon="add_circle_outline" />
            </RadzenPanelMenuItem>

            <RadzenPanelMenuItem Text="Portfolio" Path="portfolio" Icon="account_balance_wallet" />

            <RadzenPanelMenuItem Text="Users" Icon="group">
                <RadzenPanelMenuItem Text="Manage Users" Path="users" Icon="settings" />
                <RadzenPanelMenuItem Text="Create User" Path="user-create" Icon="person_add" />
            </RadzenPanelMenuItem>

            <RadzenPanelMenuItem Text="Categories" Icon="category">
                <RadzenPanelMenuItem Text="Cryptocurrency" Path="markets?category=Cryptocurrency" Icon="currency_bitcoin" />
                <RadzenPanelMenuItem Text="Technology" Path="markets?category=Technology" Icon="computer" />
                <RadzenPanelMenuItem Text="Politics" Path="markets?category=Politics" Icon="how_to_vote" />
                <RadzenPanelMenuItem Text="Sports" Path="markets?category=Sports" Icon="sports_soccer" />
                <RadzenPanelMenuItem Text="Economics" Path="markets?category=Economics" Icon="trending_up" />
                <RadzenPanelMenuItem Text="Science" Path="markets?category=Science" Icon="science" />
            </RadzenPanelMenuItem>
        </RadzenPanelMenu>

        <!-- User Info Section -->
        <RadzenStack Gap="0.5rem" class="rz-p-4 rz-mt-auto" Style="border-top: 1px solid var(--rz-border-color); background-color: var(--rz-base-100);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="account_circle" Style="font-size: 2rem; color: var(--rz-primary);" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600; margin: 0;">
                        Demo User
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); margin: 0;">
                        demo@polymarket.com
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>
    </RadzenStack>
</div>

<style>
    .rz-sidebar {
        height: 100vh;
        width: 280px;
        display: flex;
        flex-direction: column;
        background-color: var(--rz-body-background-color);
        border-right: 1px solid var(--rz-border-color);
        overflow-y: auto;
    }

    .rz-panel-menu {
        border: none !important;
    }

    .rz-panel-menu-item {
        border-bottom: none !important;
    }

    .rz-panel-menu-item-content {
        padding: 0.75rem 1rem;
        transition: all 0.2s ease;
    }

    .rz-panel-menu-item-content:hover {
        background-color: var(--rz-base-200);
    }

    .rz-panel-menu-item-wrapper.rz-state-active .rz-panel-menu-item-content {
        background-color: var(--rz-primary-lighter);
        color: var(--rz-primary);
        font-weight: 600;
    }

    .rz-panel-menu-item-icon {
        font-size: 1.25rem;
        margin-right: 0.75rem;
    }

    @@media (max-width: 768px) {
        .rz-sidebar {
            width: 100%;
            height: auto;
        }
    }
</style>
