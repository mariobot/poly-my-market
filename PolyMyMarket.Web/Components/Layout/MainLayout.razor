@inherits LayoutComponentBase
@using PolyMyMarket.Web.Services
@using Radzen
@using Radzen.Blazor
@inject UserSessionService SessionService
@implements IDisposable

<RadzenComponents @rendermode="InteractiveAuto" />
<RadzenNotification />
<RadzenDialog />

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem" Style="width: 100%;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0">
                <RadzenSidebarToggle Click="@(() => sidebar1Expanded = !sidebar1Expanded)" />
                <RadzenLabel Text="PolyMyMarket" Style="font-weight: bold; font-size: 1.25rem; margin-left: 1rem;" />
            </RadzenStack>

            @if (SessionService.CurrentUser != null)
            {
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" class="rz-pr-4">
                    <RadzenIcon Icon="account_balance_wallet" Style="color: var(--rz-success);" />
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; line-height: 1;">Active Trader</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600; margin: 0; line-height: 1.2;">
                            @SessionService.CurrentUser.Name
                        </RadzenText>
                    </RadzenStack>
                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@($"{SessionService.CurrentUser.Balance:C}")" />
                </RadzenStack>
            }
            else
            {
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-pr-4">
                    <RadzenIcon Icon="warning" Style="color: var(--rz-warning);" />
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                        No active trader
                    </RadzenText>
                </RadzenStack>
            }
        </RadzenStack>
    </RadzenHeader>
    <RadzenSidebar @bind-Expanded="@sidebar1Expanded">
        <NavMenu />
    </RadzenSidebar>
    <RadzenBody class="inner-body" style="position: relative;">
        @Body
    </RadzenBody>
</RadzenLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    bool sidebar1Expanded = true;

    protected override void OnInitialized()
    {
        SessionService.OnUserChanged += StateHasChanged;
    }

    public void Dispose()
    {
        SessionService.OnUserChanged -= StateHasChanged;
    }
}