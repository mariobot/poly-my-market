@page "/create-market"
@using PolyMyMarket.Models
@using PolyMyMarket.Web.Services
@using System.ComponentModel.DataAnnotations
@using Radzen
@using Radzen.Blazor
@inject MarketService MarketService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>Create Market - PolyMyMarket</PageTitle>

<RadzenStack Gap="1rem" class="rz-p-4 rz-p-md-12">
    <!-- Header -->
    <RadzenStack Gap="0.5rem">
        <RadzenBreadCrumb>
            <RadzenBreadCrumbItem Path="/markets" Text="Markets" Icon="show_chart" />
            <RadzenBreadCrumbItem Text="Create Market" Icon="add_circle_outline" />
        </RadzenBreadCrumb>
        <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1">Create New Market</RadzenText>
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-color-secondary">Create a new prediction market for users to trade on</RadzenText>
    </RadzenStack>

    <!-- Main Content -->
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeLG="8">
            <RadzenCard>
                <RadzenTemplateForm TItem="CreateMarketModel" Data="@model" Submit="@HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="rz-mb-4" />

                    <!-- Title -->
                    <RadzenStack Gap="1rem">
                        <RadzenFormField Text="Market Title" Variant="@Variant.Outlined">
                            <RadzenTextBox @bind-Value="@model.Title" Placeholder="e.g., Will Bitcoin reach $100,000 by end of 2025?" Style="width: 100%;" />
                        </RadzenFormField>
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
                            Make it clear and specific. Users should understand what they're betting on.
                        </RadzenText>

                        <!-- Description -->
                        <RadzenFormField Text="Description" Variant="@Variant.Outlined">
                            <RadzenTextArea @bind-Value="@model.Description" Rows="4" 
                                          Placeholder="Describe the market resolution criteria. What conditions need to be met for Yes/No outcomes?" 
                                          Style="width: 100%;" />
                        </RadzenFormField>
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
                            Explain clearly how and when this market will resolve.
                        </RadzenText>

                        <!-- Category -->
                        <RadzenFormField Text="Category" Variant="@Variant.Outlined">
                            <RadzenDropDown @bind-Value="@model.Category" Data="@categories" Style="width: 100%;" 
                                          Placeholder="-- Select Category --" />
                        </RadzenFormField>

                        <!-- Market Type -->
                        <RadzenFormField Text="Market Type" Variant="@Variant.Outlined">
                            <RadzenRadioButtonList @bind-Value="@model.MarketType" TValue="MarketType" 
                                                  Orientation="Orientation.Horizontal">
                                <Items>
                                    <RadzenRadioButtonListItem Text="Binary (Yes/No)" Value="@MarketType.Binary" />
                                    <RadzenRadioButtonListItem Text="Multi-Outcome" Value="@MarketType.MultiOutcome" />
                                </Items>
                            </RadzenRadioButtonList>
                        </RadzenFormField>
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
                            @if (model.MarketType == MarketType.Binary)
                            {
                                <span>Traditional Yes/No market</span>
                            }
                            else
                            {
                                <span>Multiple possible outcomes (e.g., election with 4 candidates)</span>
                            }
                        </RadzenText>

                        <!-- Multi-Outcome Builder -->
                        @if (model.MarketType == MarketType.MultiOutcome)
                        {
                            <RadzenFieldset>
                                <HeaderTemplate>
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <RadzenIcon Icon="list" />
                                        <RadzenText TextStyle="TextStyle.Subtitle1">Outcomes (2-10 outcomes)</RadzenText>
                                    </RadzenStack>
                                </HeaderTemplate>
                                <ChildContent>
                                    <RadzenStack Gap="0.5rem">
                                        @for (int i = 0; i < model.Outcomes.Count; i++)
                                        {
                                            var index = i;
                                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                                <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="@((index + 1).ToString())" />
                                                <RadzenTextBox @bind-Value="@model.Outcomes[index].Name" 
                                                             Placeholder="Outcome name (e.g., 'Candidate A')" 
                                                             Style="flex: 1;" />
                                                <RadzenTextBox @bind-Value="@model.Outcomes[index].Description" 
                                                             Placeholder="Optional description" 
                                                             Style="flex: 1;" />
                                                @if (model.Outcomes.Count > 2)
                                                {
                                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" 
                                                                Variant="Variant.Outlined" Size="ButtonSize.Small"
                                                                Click="@(() => RemoveOutcome(index))" />
                                                }
                                            </RadzenStack>
                                        }

                                        @if (model.Outcomes.Count < 10)
                                        {
                                            <RadzenButton Text="Add Outcome" Icon="add" ButtonStyle="ButtonStyle.Primary" 
                                                        Variant="Variant.Outlined" Size="ButtonSize.Small"
                                                        Click="@AddOutcome" />
                                        }

                                        @if (!string.IsNullOrWhiteSpace(GetOutcomeValidationMessage()))
                                        {
                                            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">
                                                @GetOutcomeValidationMessage()
                                            </RadzenAlert>
                                        }
                                    </RadzenStack>
                                </ChildContent>
                            </RadzenFieldset>
                        }

                        <RadzenRow>
                            <!-- End Date -->
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="End Date" Variant="@Variant.Outlined">
                                    <RadzenDatePicker @bind-Value="@model.EndDate" DateFormat="MM/dd/yyyy" Style="width: 100%;" />
                                </RadzenFormField>
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
                                    Trading closes on this date
                                </RadzenText>
                            </RadzenColumn>

                            <!-- Initial Liquidity -->
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Initial Liquidity" Variant="@Variant.Outlined">
                                    <RadzenNumeric @bind-Value="@model.InitialLiquidity" Format="c" Min="100" Max="1000000" 
                                                 Style="width: 100%;" ShowUpDown="false" />
                                </RadzenFormField>
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
                                    Minimum: $100. Higher liquidity = less price slippage
                                </RadzenText>
                            </RadzenColumn>
                        </RadzenRow>

                        <!-- Market Preview -->
                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter">
                            <RadzenStack Gap="0.5rem">
                                <RadzenText TextStyle="TextStyle.Subtitle2">Market Preview</RadzenText>
                                @if (model.MarketType == MarketType.Binary)
                                {
                                    <RadzenText TextStyle="TextStyle.Body2">
                                        <strong>Initial Yes Price:</strong> 50¢ (50%)
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2">
                                        <strong>Initial No Price:</strong> 50¢ (50%)
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2">
                                        <strong>Yes Pool:</strong> @((model.InitialLiquidity / 2).ToString("C"))
                                        <span class="rz-mx-2">|</span>
                                        <strong>No Pool:</strong> @((model.InitialLiquidity / 2).ToString("C"))
                                    </RadzenText>
                                }
                                else
                                {
                                    var validOutcomes = model.Outcomes.Where(o => !string.IsNullOrWhiteSpace(o.Name)).ToList();
                                    var liquidityPerOutcome = validOutcomes.Any() ? model.InitialLiquidity / validOutcomes.Count : 0;
                                    var pricePerOutcome = validOutcomes.Any() ? 1.0m / validOutcomes.Count : 0;

                                    <RadzenText TextStyle="TextStyle.Body2">
                                        <strong>Outcomes:</strong> @validOutcomes.Count
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2">
                                        <strong>Initial Price per Outcome:</strong> @((pricePerOutcome * 100).ToString("F1"))¢ (@((pricePerOutcome * 100).ToString("F1"))%)
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2">
                                        <strong>Liquidity per Outcome:</strong> @liquidityPerOutcome.ToString("C")
                                    </RadzenText>
                                }
                            </RadzenStack>
                        </RadzenAlert>

                        <!-- Buttons -->
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton ButtonType="ButtonType.Submit" Text="Create Market" Icon="add_circle" 
                                        ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large"
                                        Disabled="@isSubmitting" IsBusy="@isSubmitting" BusyText="Creating..." />
                            <RadzenButton Text="Cancel" Icon="close" ButtonStyle="ButtonStyle.Light" 
                                        Size="ButtonSize.Large" Click="@(() => Navigation.NavigateTo("/markets"))" />
                        </RadzenStack>
                    </RadzenStack>
                </RadzenTemplateForm>
            </RadzenCard>
        </RadzenColumn>

        <!-- Guidelines Sidebar -->
        <RadzenColumn Size="12" SizeLG="4">
            <RadzenCard class="rz-shadow-3">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="checklist" Style="color: var(--rz-primary);" />
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Market Guidelines</RadzenText>
                    </RadzenStack>

                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Good Market Criteria:</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
                            <ul style="margin: 0; padding-left: 1.25rem;">
                                <li>Clear, unambiguous resolution conditions</li>
                                <li>Verifiable outcome from reliable sources</li>
                                <li>Reasonable timeframe</li>
                                <li>Binary (Yes/No) or multi-outcome format</li>
                                <li>Not offensive or inappropriate</li>
                            </ul>
                        </RadzenText>
                    </RadzenStack>

                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Examples of Good Markets:</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
                            <ul style="margin: 0; padding-left: 1.25rem;">
                                <li><strong>Binary:</strong> "Will Bitcoin reach $100K by Dec 31, 2025?"</li>
                                <li><strong>Multi-Outcome:</strong> "Who will win the 2028 US Presidential Election?"</li>
                                <li><strong>Multi-Outcome:</strong> "Which team will win the Super Bowl 2026?"</li>
                            </ul>
                        </RadzenText>
                    </RadzenStack>

                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Avoid:</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
                            <ul style="margin: 0; padding-left: 1.25rem;">
                                <li>Vague or subjective outcomes</li>
                                <li>Markets that can't be verified</li>
                                <li>Offensive or inappropriate content</li>
                                <li>Markets that violate laws or regulations</li>
                            </ul>
                        </RadzenText>
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>

            <RadzenCard class="rz-shadow-3 rz-mt-4">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="tips_and_updates" Style="color: var(--rz-warning);" />
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Pro Tips</RadzenText>
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
                        <ul style="margin: 0; padding-left: 1.25rem;">
                            <li>Set end dates 1-2 weeks before resolution date</li>
                            <li>Higher liquidity attracts more traders</li>
                            <li>Reference specific sources for resolution</li>
                            <li>Consider time zones in your criteria</li>
                        </ul>
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    private CreateMarketModel model = new();
    private bool isSubmitting = false;
    private List<string> categories = new()
    {
        "Cryptocurrency",
        "Technology",
        "Economics",
        "Politics",
        "Sports",
        "Entertainment",
        "Science",
        "Space",
        "Other"
    };

    protected override void OnInitialized()
    {
        // Set default values
        model.EndDate = DateTime.UtcNow.AddMonths(3).Date;
        model.InitialLiquidity = 1000m;
        model.MarketType = MarketType.Binary;

        // Initialize with 2 empty outcomes for multi-outcome
        model.Outcomes.Add(new OutcomeModel { Name = "", Description = "" });
        model.Outcomes.Add(new OutcomeModel { Name = "", Description = "" });
    }

    private void AddOutcome()
    {
        if (model.Outcomes.Count < 10)
        {
            model.Outcomes.Add(new OutcomeModel { Name = "", Description = "" });
        }
    }

    private void RemoveOutcome(int index)
    {
        if (model.Outcomes.Count > 2)
        {
            model.Outcomes.RemoveAt(index);
        }
    }

    private string? GetOutcomeValidationMessage()
    {
        if (model.MarketType != MarketType.MultiOutcome) return null;

        var validOutcomes = model.Outcomes.Where(o => !string.IsNullOrWhiteSpace(o.Name)).ToList();

        if (validOutcomes.Count < 2)
            return "At least 2 outcomes are required";

        var duplicates = validOutcomes.GroupBy(o => o.Name.Trim().ToLower())
            .Where(g => g.Count() > 1)
            .Select(g => g.Key)
            .ToList();

        if (duplicates.Any())
            return $"Duplicate outcome names: {string.Join(", ", duplicates)}";

        return null;
    }

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;

        try
        {
            // Validate multi-outcome markets
            if (model.MarketType == MarketType.MultiOutcome)
            {
                var validationMessage = GetOutcomeValidationMessage();
                if (!string.IsNullOrWhiteSpace(validationMessage))
                {
                    NotificationService.Notify(new NotificationMessage 
                    { 
                        Severity = NotificationSeverity.Error, 
                        Summary = "Validation Error", 
                        Detail = validationMessage, 
                        Duration = 4000 
                    });
                    isSubmitting = false;
                    return;
                }
            }

            // Create market object
            var market = new Market
            {
                Title = model.Title,
                Description = model.Description,
                Category = model.Category,
                MarketType = model.MarketType,
                EndDate = model.EndDate.ToUniversalTime(),
                InitialLiquidity = model.InitialLiquidity,
                Status = MarketStatus.Active,
                CreatedDate = DateTime.UtcNow
            };

            if (model.MarketType == MarketType.Binary)
            {
                // Binary market: set up Yes/No pools
                market.YesPool = model.InitialLiquidity / 2;
                market.NoPool = model.InitialLiquidity / 2;
            }
            else
            {
                // Multi-outcome market: create outcomes
                var validOutcomes = model.Outcomes
                    .Where(o => !string.IsNullOrWhiteSpace(o.Name))
                    .ToList();

                decimal liquidityPerOutcome = model.InitialLiquidity / validOutcomes.Count;

                for (int i = 0; i < validOutcomes.Count; i++)
                {
                    market.Outcomes.Add(new MarketOutcome
                    {
                        Name = validOutcomes[i].Name.Trim(),
                        Description = validOutcomes[i].Description?.Trim() ?? string.Empty,
                        DisplayOrder = i + 1,
                        LiquidityPool = liquidityPerOutcome,
                        IsWinner = false
                    });
                }

                // Set legacy pools to 0 for multi-outcome
                market.YesPool = 0;
                market.NoPool = 0;
            }

            var result = await MarketService.CreateMarketAsync(market);

            if (result.success)
            {
                NotificationService.Notify(new NotificationMessage 
                { 
                    Severity = NotificationSeverity.Success, 
                    Summary = "Success", 
                    Detail = "Market created successfully!", 
                    Duration = 4000 
                });
                await Task.Delay(1500);
                Navigation.NavigateTo($"/market/{result.marketId}");
            }
            else
            {
                NotificationService.Notify(new NotificationMessage 
                { 
                    Severity = NotificationSeverity.Error, 
                    Summary = "Error", 
                    Detail = result.message, 
                    Duration = 4000 
                });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage 
            { 
                Severity = NotificationSeverity.Error, 
                Summary = "Error", 
                Detail = $"Error creating market: {ex.Message}", 
                Duration = 4000 
            });
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class CreateMarketModel
    {
        [Required(ErrorMessage = "Title is required")]
        [StringLength(200, MinimumLength = 10, ErrorMessage = "Title must be between 10 and 200 characters")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "Description is required")]
        [StringLength(2000, MinimumLength = 50, ErrorMessage = "Description must be between 50 and 2000 characters")]
        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "Category is required")]
        public string Category { get; set; } = string.Empty;

        [Required(ErrorMessage = "End date is required")]
        public DateTime EndDate { get; set; } = DateTime.UtcNow.AddMonths(3);

        [Required(ErrorMessage = "Initial liquidity is required")]
        [Range(100, 1000000, ErrorMessage = "Initial liquidity must be between $100 and $1,000,000")]
        public decimal InitialLiquidity { get; set; } = 1000m;

        public MarketType MarketType { get; set; } = MarketType.Binary;

        public List<OutcomeModel> Outcomes { get; set; } = new();
    }

    public class OutcomeModel
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
}
